{
  "name": "texpulse-studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/electron/main.js",
  "bin": {
    "texpulse-compile": "./dist/cli/compile.js",
    "texpulse-doctor": "./dist/cli/doctor.js"
  },
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=24 <25",
    "pnpm": "10.12.1"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.1"
    }
  },
  "scripts": {
    "app:start": "pnpm build && electron .",
    "build": "pnpm build:node && pnpm build:renderer && pnpm build:preload",
    "build:node": "tsc -p tsconfig.build.json",
    "build:preload": "vite build --config vite.preload.config.ts",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test:unit && pnpm test:component && pnpm test:integration && pnpm test:coverage && pnpm test:e2e && pnpm build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test:e2e": "pnpm build && playwright test",
    "test:coverage": "vitest run --coverage",
    "test:component": "vitest run tests/component",
    "test:integration": "vitest run tests/integration",
    "test:unit": "vitest run tests/unit",
    "texpulse-compile": "pnpm build && node ./dist/cli/compile.js",
    "texpulse-doctor": "pnpm build && node ./dist/cli/doctor.js",
    "typecheck": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@eslint/js": "9.29.0",
    "@playwright/test": "1.60.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.0.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "electron": "42.4.0",
    "eslint": "9.29.0",
    "globals": "16.2.0",
    "jsdom": "29.1.1",
    "prettier": "3.5.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.34.1",
    "vite": "8.0.16",
    "vitest": "4.1.8",
    "yaml": "2.9.0"
  },
  "dependencies": {
    "@codemirror/language": "6.12.3",
    "@codemirror/legacy-modes": "6.5.3",
    "@codemirror/state": "6.6.0",
    "@codemirror/view": "6.43.1",
    "chokidar": "5.0.0",
    "codemirror": "6.0.2",
    "pdfjs-dist": "6.0.227",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  }
}
